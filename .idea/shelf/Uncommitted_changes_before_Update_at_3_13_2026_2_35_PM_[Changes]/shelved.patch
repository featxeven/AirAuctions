<+># ----------------------------------\r\n# AirAuctions Configuration\r\n# ----------------------------------\r\n\r\n# ----------------------------------\r\n# GENERAL\r\n# ----------------------------------\r\n# Global options\r\nnotify-updates: true               # Notify admins when there is a new update\r\nlang: \"en_US\"                      # Locale file name (lang/messages/KEY.yml)\r\nerror-on-excess-args: true         # Show error message if too many arguments are provided (for commands)\r\n\r\n# Time formatting used across the plugin and in placeholders\r\ntime-format:\r\n  # Modes: DETAILED | SEQUENTIAL | CUSTOM\r\n  # DETAILED   - show all relevant units (\"2 days 3 hours 4 minutes 20 seconds\")\r\n  # SEQUENTIAL - show one unit at a time (used for progressive messages)\r\n  # CUSTOM     - show up to 'granularity' units (useful for short displays)\r\n  mode: CUSTOM\r\n  granularity: 2   # Only used when mode = CUSTOM (1 = largest only, 4 = full breakdown)\r\n\r\n# Date formatting used for GUIs\r\n# Common patterns:\r\n# dd/MM/yy      -> 08/03/26\r\n# dd MMM        -> 08 Mar\r\n# MMMM dd, yyyy -> March 08, 2026\r\n# E, dd MMM     -> Sun, 08 Mar\r\ndate-format: \"dd/MM/yy\"\r\n\r\n# true:  Always reopens GUI when using filter or sort buttons\r\n# false: Updates only auction slots (better for performance)\r\nforce-update-gui: true\r\n\r\n# true:  \"\" lines are hidden UNLESS visible lines appear below them.\r\n# false: Show all lines regarding if they are empty (\"\").\r\nskip-empty-lines: true\r\n\r\n# ----------------------------------\r\n# AUCTIONS\r\n# ----------------------------------\r\nauctions:\r\n  # --- General Settings ---\r\n  max-listings: 3                  # Max listings per player (bypass with airauctions.bypass.limit.<#>)\r\n  history-item-limit: 50           # Max entries stored in player auction history GUI (-1 to disable)\r\n  expired-item-limit: 50           # Max entries stored in player expired auctions GUI (-1 to disable)\r\n  auction-cooldown: 5              # Seconds between creating new listings (-1 to disable)\r\n  purge-time: -1                   # Seconds before an expired item is deleted from DB (-1 to disable)\r\n  expire-time: 86400               # Duration in seconds before a listing expires (bypass with airauctions.bypass.expire-time.<#>)\r\n  broadcast-to-self: false         # If true, the seller also receives the global 'new listing' broadcast.\r\n\r\n  # --- Listing Process ---\r\n  confirm-auction: true            # Enable confirmation before listing an item\r\n  confirmation-expire-time: 60     # Seconds before confirmation request expires if Confirm GUI is disabled (-1 to disable)\r\n\r\n  # Amount Requirement:\r\n  # REQUIRED: Player MUST choose an amount via command.\r\n  # OPTIONAL: Uses item in hand amount if no amount is specified.\r\n  # DISABLED: Ignores the amount argument and always lists the entire stack in hand.\r\n  amount-type: OPTIONAL\r\n\r\n  # --- Purchasing & Cancellation ---\r\n  purchase-own: false              # Allows the player to buy their own auctions\r\n  drop-items-when-full: true       # Drop purchased items on floor if inventory is full\r\n\r\n  # --- Sorting ---\r\n  # Define the available sorting modes used in the GUIs.\r\n  # The order here determines the order they appear on the GUIs.\r\n  sorting:\r\n    newest-date: \"Newest date\"\r\n    oldest-date: \"Oldest date\"\r\n    highest-price: \"Highest price\"\r\n    lowest-price: \"Lowest price\"\r\n    alphabetical: \"Alphabetical\"\r\n    amount: \"Amount\"\r\n\r\n# ----------------------------------\r\n# ECONOMY\r\n# ----------------------------------\r\neconomy:\r\n  # Default currency to use\r\n  default-currency: \"vault\"\r\n\r\n  # Define your currency providers here\r\n  # You can use 'VAULT', 'EXP' (internal) or 'PLACEHOLDER' (external)\r\n  providers:\r\n    vault:\r\n      type: VAULT\r\n      display: \"<green>$%amount%</green>\"\r\n      allow-decimals: true\r\n\r\n    exp:\r\n      type: EXP\r\n      display: \"<green>%amount% XP Points</green>\"\r\n      allow-decimals: false\r\n\r\n    # You can add your own currencies.\r\n    crystals:\r\n      type: PLACEHOLDER\r\n      display: \"<gold>%amount% Crystals</gold>\"\r\n      # The currency must support decimals to enable this\r\n      allow-decimals: false\r\n      # For PLACEHOLDER type, these settings are required\r\n      settings:\r\n        balance-placeholder: \"%mycurrency_balance%\"\r\n        give-command: \"mycurrency give %player% %amount%\"\r\n        take-command: \"mycurrency take %player% %amount%\"\r\n        # Enable if the placeholder works for offline players\r\n        offline-support: false\r\n\r\n  number-format: SHORT             # SHORT (1k) | FORMATTED (1,000) | RAW (1000)\r\n  format-short-suffix: [\"\", \"k\", \"M\", \"B\", \"T\", \"Q\"]\r\n  allow-format-short-in-command: true # Allow '1k' instead of '1000' in commands\r\n\r\n  # --- Listing price constraints ---\r\n  min-auction-price: 5             # Minimum price to list an item\r\n  max-auction-price: 10000000      # Maximum price to list an item (-1 to disable)\r\n\r\n  # --- Listing Fees & Taxes ---\r\n  # Fees are taken when a player RUNS the /ah sell command.\r\n  # Taxes are taken from the profit when the item is actually BOUGHT.\r\n  listing-fee:\r\n    enabled: true\r\n    # Use 'PERCENTAGE' of the asking price, or 'FIXED' for a flat cost per item.\r\n    type: PERCENTAGE\r\n\r\n    # Default values if no specific permission is found\r\n    default-value: 10             # 10% fee or $10 fixed. IF FIXED, it will ignore the other 2 options from below\r\n    min-fee: 1                    # Minimum amount to charge (prevents $0.01 fees)\r\n    max-fee: 1000                 # Maximum amount to charge (-1 to disable)\r\n\r\n  sales-tax:\r\n    enabled: true\r\n    # This is deducted from the seller's earnings upon a successful sale.\r\n    # Use 'PERCENTAGE' of the asking price, or 'FIXED' for a flat cost per item.\r\n    type: PERCENTAGE\r\n\r\n    # Default values if no specific permission is found\r\n    default-value: 10             # 10% tax or $10 fixed, IF FIXED, it will ignore the other 2 options from below\r\n    min-fee: 1                    # Minimum amount to tax (prevents $0.01 tax)\r\n    max-fee: 1000                 # Maximum amount to tax (-1 to disable)\r\n\r\n# ----------------------------------\r\n# COMMAND & SUBCOMMANDS\r\n# ----------------------------------\r\ncommands:\r\n  # Requires restart to reflect changes\r\n  main:\r\n    name: \"auctionhouse\"\r\n    aliases: [ah, auctions]\r\n    usage: \"/%label% [subcommand] [...]\"\r\n\r\n  subcommands:\r\n    sell:\r\n      enabled: true\r\n      name: \"sell\"\r\n      usage: \"/%label% %sublabel% <price> [amount]\"\r\n    listings:\r\n      enabled: true\r\n      name: \"listings\"\r\n      usage: \"/%label% %sublabel%\"\r\n    expired:\r\n      enabled: true\r\n      name: \"expired\"\r\n      usage: \"/%label% %sublabel%\"\r\n    history:\r\n      enabled: true\r\n      name: \"history\"\r\n      usage: \"/%label% %sublabel%\"\r\n      usage-others: \"/%label% %sublabel% [player]\"\r\n    search:\r\n      enabled: true\r\n      name: \"search\"\r\n      usage: \"/%label% %sublabel% <query>\"\r\n    view-player:\r\n      enabled: true\r\n      name: \"player\"\r\n      usage: \"/%label% %sublabel% <player>\"\r\n    open:\r\n      enabled: true\r\n      name: \"open\"\r\n      usage: \"/%label% %sublabel% <gui-id> <filter> <sort>\"\r\n      usage-others: \"/%label% %sublabel% <gui-id> <filter> <sort> [player]\"\r\n\r\n# ----------------------------------\r\n# RESTRICTIONS\r\n# ----------------------------------\r\nrestrictions:\r\n  blocked-gamemodes:               # Gamemodes where players cannot auction items (bypass with airauctions.bypass.gamemodes)\r\n    - CREATIVE\r\n    - SPECTATOR\r\n\r\n  disabled-worlds:                 # Worlds where players cannot auction items (bypass with airauctions.bypass.worlds)\r\n    - \"disabled_world\"\r\n\r\n  allow-damaged-items: true        # Allows the player to auction damaged items (bypass with airauctions.bypass.damageditems)\r\n  max-query-length: 32             # Maximum characters allowed in a search query\r\n\r\n  # --- Item Blacklist ---\r\n  # Define what items cannot be listed on the auction house. (bypass with airauctions.bypass.blacklist)\r\n  # If 'as-whitelist' is true, ONLY items matching these rules can be listed.\r\n  item-blacklist:\r\n    as-whitelist: false\r\n\r\n    # Match by Bukkit Material names (e.g., BARRIER, BEDROCK)\r\n    materials:\r\n      - COMMAND_BLOCK\r\n      - BEDROCK\r\n      - BARRIER\r\n\r\n    # Match by Display Name or Lore (supports partial matches, ignores colors)\r\n    # Syntax for lores: \"line_index:text\" or just \"text\" to search all lines.\r\n    names:\r\n      - \"Soulbound Item\"\r\n      - \"Quest Item\"\r\n    lores:\r\n      - \"0:Not for Sale\"\r\n      - \"Soulbound\"\r\n\r\n    # Match by Enchantment and Level\r\n    # Syntax: \"ENCHANT_NAME\" (any level) or \"ENCHANT_NAME:LEVEL\"\r\n    enchantments:\r\n      - \"BINDING_CURSE\"\r\n      - \"VANISHING_CURSE:1\"\r\n\r\n    # Match by NBT data, Custom Model Data, or Item Model\r\n    # Syntax for models: \"DATA\" (any material) or \"MATERIAL:DATA\"\r\n    nbt-keys:\r\n      - \"undroppable\"\r\n      - \"unique_id\"\r\n    custom-model-data:\r\n      - \"1005\"\r\n      - \"PAPER:1002\"\r\n    item-models:\r\n      - \"custom:mymodel/admin_pickaxe\"\r\n      - \"minecraft:broken_shield\"\r\n\r\n    # Match Nexo, ItemsAdder  items\r\n    special-items: []\r\n    #  - \"nexo:item_id\"\r\n    #  - \"itemsadder:item_id\"\r\n\r\n    # Match exact item stacks (advanced)\r\n    # Used for items that need specific data/material combinations.\r\n    specific-items:\r\n      example_restriction:\r\n        material: STICK\r\n        name: \"Admin Stick\"\r\n        glow: true
